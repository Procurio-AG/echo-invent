# Local Docker Postgres — the 2 keys that abstract the whole DB layer.
#
# These are the SAME two variables Supabase uses; only the values change.
# Copy this file to .env (or run ./scripts/db-switch.sh local) to go local.
#
# Unlike Supabase there is no PgBouncer locally, so:
#   - both URLs point at the same instance (port 5432)
#   - the ?pgbouncer=true flag is DROPPED (would break prepared statements)
#
# Credentials match docker-compose.yml (echo / echo / echo). Throwaway — local only.

# Runtime (Prisma Client) — same target, no pooler locally
DATABASE_URL="postgresql://echo:echo@localhost:5432/echo?schema=public"

# Migrations (prisma migrate) — identical to DATABASE_URL when running locally
DIRECT_URL="postgresql://echo:echo@localhost:5432/echo?schema=public"
