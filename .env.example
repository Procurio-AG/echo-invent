# Supabase Postgres connection strings
# Pooled connection (used by Prisma Client at runtime)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Gemini API keys for voice rapid-capture speech-to-text (server-side only — never
# exposed to the client). Provide ONE OR MORE keys, comma-separated. Each key should
# come from a SEPARATE Google AI Studio project/account, since free-tier rate limits
# (RPM/RPD) are per project — more keys = proportionally more throughput. The server
# rotates across them round-robin and fails over on a 429 (rate-limited) key.
GEMINI_API_KEYS="key_from_account_1,key_from_account_2,key_from_account_3"

# Supabase Storage for product images (server-side only — the SERVICE ROLE key
# bypasses RLS, so never expose it to the client / never use a NEXT_PUBLIC_ prefix).
# Create a PRIVATE bucket named "product-images" (2MB file-size limit, allowed MIME
# image/jpeg, image/webp, image/png) in the Supabase dashboard. The server signs
# short-lived URLs for in-app display and streams bytes into the export zip, so the
# bucket never needs to be public.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# Optional override; defaults to "product-images"
SUPABASE_STORAGE_BUCKET="product-images"
